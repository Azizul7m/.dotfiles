{
  "explorer.width": 30,
  "explorer.buffer.root.template": "[icon & 1] OPEN EDITORS",
  "explorer.file.root.template": "[icon & 1] PROJECT ([root])",
  "explorer.file.child.template": "[git | 2] [selection | clip | 1] [indent][icon | 1] [diagnosticError & 1][filename omitCenter 1][modified][readonly] [linkIcon & 1][link growRight 1 omitCenter 5]",
  "explorer.file.showHiddenFiles": true,
  "explorer.openAction.relativePath": true,
  //"explorer.icon.enableVimDevicons": true,
  "explorer.icon.enableNerdfont": true,
  "explorer.previewAction.onHover": false,
  "explorer.keyMappings.global": {
    /* some mapping adapted from nerdtree */
    "s": "open:vsplit",
    "mm": "rename",
    "mc": "copyFile",
    "C": "copyFile",
    "md": "delete",
    "D": "delete",
    "ma": "addFile",
    "mA": "addDirectory"
  },
  "diagnostic.errorSign": "●",
  "diagnostic.warningSign": "●",
  "diagnostic.infoSign": "●",
  "diagnostic.hintSign": "●",
  /* "diagnostic.errorSign": "E", */
  /* "diagnostic.warningSign": "W", */
  /* "diagnostic.infoSign": "I", */
  /* "diagnostic.hintSign": "H", */
  "diagnostic.checkCurrentLine": true,
  "javascript.suggest.enabled": false,
  "python.jediEnabled": false,
  "python.analysis.disabled": [
    "inherit-non-class"
  ],
  "coc.preferences.rootPatterns": [
    ".vim",
    ".git",
    ".hg",
    ".projections.json"
  ],
  "diagnostic.refreshOnInsertMode": true,
  "coc.preferences.formatOnSaveFiletypes": [
    "python",
    "json",
    "css",
    "scss",
    "less",
    "Markdown",
    "javascript",
    "javascript.vue",
    "javascript.jsx"
  ],
  "suggest.timeout": 15000,
  // Python
  "diagnostic-languageserver.filetypes": {
    "python": "flake8"
  },
  "html.format.enable": true,
  "html.format.preserveNewLines": true,
  "html.format.maxPreserveNewLines": 2,
  "html.format.indentInnerHtml": false,
  "html.format.wrapAttributes": "force",
  //"html.format.wrapAttributesIndentSize": 4,
  "html.suggest.html5": true,
  "suggest.floatEnable": true,
  "diagnostic.messageTarget": "float",
  "signature.target": "float"
}
